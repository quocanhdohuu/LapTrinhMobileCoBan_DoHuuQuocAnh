<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/logohotel"
        android:label="Booking Hotel"
        android:roundIcon="@drawable/logohotel"
        android:supportsRtl="true"
        android:theme="@style/Theme.BTL_Mobile">

        <activity
            android:name=".SplashActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".LoginActivity" />
        <activity android:name=".RegisterActivity" />
        <activity android:name=".MainActivity" />
        <activity android:name=".CustomerActivity" />
        <activity android:name=".RoomDetailActivity" />
        <activity android:name=".BookingActivity" />
        <activity android:name=".BookingDetailActivity" />

    </application>

</manifest>
